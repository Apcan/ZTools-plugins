{
  "name": "ztools-image-batch-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ZTools image batch processing plugin.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5177",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "build": "vite build && tsc -p tsconfig.preload.json && node scripts/prepare-dist.mjs",
    "install:local": "node scripts/install-local.mjs",
    "smoke:installed": "node scripts/smoke-installed.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "gifenc": "1.0.3",
    "lucide-react": "latest",
    "pdf-lib": "1.17.1",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "lmdb": "^3.4.2",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
